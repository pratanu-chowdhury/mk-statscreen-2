# ---- Turso (libSQL / SQLite) ----
# Create these with the Turso CLI:
#   turso db create mk-statscreen
#   turso db show mk-statscreen --url        ->  TURSO_DATABASE_URL
#   turso db tokens create mk-statscreen     ->  TURSO_AUTH_TOKEN
# Leave them blank to run with browser-only (localStorage) persistence.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Port the API/server listens on (Render/Railway/Fly set this automatically)
PORT=8787

# Frontend origin allowed to call the API (production). Default "*".
CORS_ORIGIN=

# Only if hosting the frontend separately (e.g. Lovable). Absolute API origin.
# Used at BUILD time by Vite. Leave blank when one server hosts both.
VITE_API_URL=
